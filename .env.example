# URL Prisma Accelerate (runtime app + Cloudflare Workers)
# console.prisma.io → votre base → Enable Accelerate → copier l'URL "Accelerate"
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY"

# Connexion PostgreSQL directe (migrations, seed, prisma studio uniquement)
# console.prisma.io → Connect → "Direct connection"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Clé secrète Auth.js — générer avec : openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# URL publique du site en production (Auth.js / callbacks)
AUTH_URL="https://pbgtelecom.fr"

# URL publique exposée au navigateur (SEO, liens absolus)
NEXT_PUBLIC_SITE_URL="https://pbgtelecom.fr"

# Stripe (optionnel — laisser vide si non configuré)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
