# URL PostgreSQL — récupérée depuis Prisma Postgres (https://console.prisma.io)
# ou Neon (https://neon.tech). En local, utilisez la même URL ou une branche dev gratuite.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Clé secrète Auth.js — générer avec : openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# URL publique du site en production (Auth.js / callbacks)
AUTH_URL="https://pbgtelecom.fr"

# URL publique exposée au navigateur (SEO, liens absolus)
NEXT_PUBLIC_SITE_URL="https://pbgtelecom.fr"

# Stripe (optionnel — laisser vide si non configuré)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
